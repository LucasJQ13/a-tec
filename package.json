{
  "name": "atec-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:prebuild": "expo prebuild --platform android",
    "android:prebuild:clean": "expo prebuild --platform android --clean",
    "android:export": "expo export --platform android --clear",
    "android:debug": "set NODE_ENV=development&& cd android && gradlew.bat :app:assembleDebug",
    "android:release": "set NODE_ENV=production&& cd android && gradlew.bat :app:assembleRelease",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "dev:localhost": "scripts\\start-localhost.cmd",
    "dev:mobile": "scripts\\start-expo-mobile.cmd",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "@supabase/supabase-js": "2.80.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-image-picker": "~17.0.11",
    "expo-notifications": "~0.32.17",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
